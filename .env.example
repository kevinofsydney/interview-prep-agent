APP_ACCESS_PASSWORD=change-me

OPENROUTER_API_KEY=

# MVP model progression, all via OpenRouter:
# 1. Gemma 4 for earliest MVP testing
# 2. DeepSeek V4 Flash when the workflow needs stronger cheap synthesis
# 3. GLM 5.2 as the production candidate
#
# Replace these values with the exact OpenRouter model IDs available in your
# OpenRouter account when wiring real LLM calls.
RESEARCH_MODEL=gemma-4
SYNTHESIS_MODEL=gemma-4
FINAL_MODEL=gemma-4

MAX_RUN_COST_USD=1.00
MAX_DAILY_COST_USD=5.00
MAX_INPUT_TOKENS_PER_RUN=60000
MAX_OUTPUT_TOKENS_PER_RUN=12000
