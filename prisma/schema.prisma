generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobRuns JobRun[]
}

model JobRun {
  id               String   @id @default(uuid())
  userId           String
  companyName      String
  roleTitle        String
  jobDescription   String
  resumeText       String
  interviewStage   String
  recruiterNotes   String?
  status           String   @default("draft")
  statusReason     String?
  idempotencyKey   String?
  sourceCount      Int      @default(0)
  estimatedCostUsd Float    @default(0)
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources    Source[]
  tasks      AgentTask[]
  report     Report?
  modelUsage ModelUsage[]

  @@index([userId])
  @@index([status])
}

model Source {
  id          String   @id @default(uuid())
  jobRunId    String
  userId      String
  title       String
  sourceType  String
  contentText String
  tokenCount  Int      @default(0)
  confidence  String   @default("high")
  createdAt   DateTime @default(now())

  jobRun JobRun @relation(fields: [jobRunId], references: [id], onDelete: Cascade)

  @@index([jobRunId])
  @@index([userId])
}

model AgentTask {
  id             String   @id @default(uuid())
  jobRunId       String
  userId         String
  agent          String
  status         String   @default("queued")
  description    String
  resultJson     Json?
  rawOutput      String?
  errorMessage   String?
  retriesUsed    Int      @default(0)
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  estimatedCost  Float    @default(0)
  model          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobRun     JobRun       @relation(fields: [jobRunId], references: [id], onDelete: Cascade)
  modelUsage ModelUsage[]

  @@index([jobRunId])
  @@index([userId])
  @@index([status])
}

model Report {
  id        String   @id @default(uuid())
  jobRunId  String   @unique
  userId    String
  title     String
  reportJson Json
  markdown  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobRun JobRun @relation(fields: [jobRunId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ModelUsage {
  id                String   @id @default(uuid())
  jobRunId          String
  agentTaskId       String
  userId            String
  provider          String
  model             String
  inputTokens       Int
  outputTokens      Int
  cachedInputTokens Int      @default(0)
  estimatedCostUsd  Float
  latencyMs         Int      @default(0)
  status            String   @default("recorded")
  createdAt         DateTime @default(now())

  jobRun    JobRun    @relation(fields: [jobRunId], references: [id], onDelete: Cascade)
  agentTask AgentTask @relation(fields: [agentTaskId], references: [id], onDelete: Cascade)

  @@index([jobRunId])
  @@index([userId])
  @@index([model])
}
